# Electron Production Build Konfiguration
# Kopiere diese Datei zu .env.electron und fülle die Werte aus.
#
# VITE_APP_URL: Für WalletConnect Domain-Verifikation.
# Auf die echte öffentliche URL setzen wenn vorhanden (z.B. https://dashboard.mebtc.io)

VITE_REOWN_PROJECT_ID=YOUR_REOWN_PROJECT_ID
VITE_APP_URL=http://localhost:5173

# Direkte HTTPS-URLs — kein Vite-Proxy nötig in Electron
VITE_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
VITE_AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
VITE_TARGET_CHAIN_ID=43113
