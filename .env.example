# Required
VITE_REOWN_PROJECT_ID=YOUR_REOWN_PROJECT_ID

# Optional
VITE_APP_URL=http://localhost:5173
# Dev only: /fuji uses Vite proxy. For preview/build use full URL.
VITE_FUJI_RPC_URL=/fuji
VITE_AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
VITE_TARGET_CHAIN_ID=43113

# Monitoring / telemetry (optional)
# HTTP endpoint that accepts JSON events via POST (one event per request).
VITE_MONITORING_INGEST_URL=
VITE_MONITORING_ENV=development
# Set to true only for local debugging (writes events to browser console).
VITE_MONITORING_LOG_TO_CONSOLE=false
